datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Brand {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())
  storeUrl      String
  domain        String      @unique
  name          String
  palette       Json // { swatches: [{ hex, labL, labA, labB, weight }, ...] }
  photoStyle    String // "studio" | "lifestyle" | "ugc" | "mixed"
  typography    Json // { family, weight, casing }
  toneWords     String[] // max 5
  toneVector    Float[] // 3072-dim embedding
  sourceAssets  Json // { pdpImages: string[], igImages: string[] }
  productHeroes Json // [{ url, sku, embedding: Float[] }]
  candidates    Candidate[]
}

model Candidate {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id])
  imageUrl  String
  createdAt DateTime @default(now())
  scoring   Scoring?
}

model Scoring {
  id              String    @id @default(cuid())
  candidateId     String    @unique
  candidate       Candidate @relation(fields: [candidateId], references: [id])
  paletteMatch    Float
  typographyMatch Float
  photoStyleMatch Float
  productAccuracy Float
  onBrandOverall  Float
  explanation     String
  matchedHero     String?
  createdAt       DateTime  @default(now())
}

// --- Auth ---

// Wasp-managed business-logic user. Auth/Identity/Session tables are added
// automatically by Wasp's compiler once `auth` is configured in main.wasp.ts;
// this model only needs to exist as the thing they attach to.
model User {
  id            String        @id @default(cuid())
  createdAt     DateTime      @default(now())
  // Mirrors the underlying email-identity's verification flag, set by the
  // onAfterEmailVerified hook (src/auth/hooks.ts). Kept as a plain column
  // here so verifyMcpSecret can check it with a single findUnique on User —
  // MCP requests carry no Wasp session, so there is no `context.user` to read
  // `identities.email.isEmailVerified` off of; this avoids reaching into
  // Wasp's internal Auth/AuthIdentity tables from an unrelated request.
  emailVerified Boolean       @default(false)
  // Per-account MCP quota tier. New self-service signups start at DEFAULT;
  // an operator can bump this column for a specific account when needed.
  mcpTier       McpApiKeyTier @default(DEFAULT)
  apiKeys       McpApiKey[]
}

enum McpApiKeyTier {
  DEFAULT
  PRO
  ADMIN
}

// Per-caller MCP credential. Only one-way argon2id hashes are persisted; the
// plaintext key is returned to the owner exactly once, at creation time, and
// never stored or logged anywhere. keyFingerprint is a short display-only
// slice of the lookup hash so users can tell keys apart without persisting
// any plaintext key material.
model McpApiKey {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyHash        String        @unique
  // Deterministic argon2id lookup hash of the plaintext key. This is the
  // DB selector for MCP auth; keyHash above remains the salted verifier.
  keyLookupHash  String?       @unique
  keyFingerprint String?
  name           String?
  tier           McpApiKeyTier @default(DEFAULT)
  createdAt      DateTime      @default(now())
  revokedAt      DateTime?
  lastUsedAt     DateTime?

  @@index([userId])
}

// --- Security / abuse-control tables ---

// One row per priced LLM call. Daily spend caps are computed by summing
// usdCost for a provider since the start of the current UTC day.
model ApiUsage {
  id        String   @id @default(cuid())
  provider  String // "anthropic" | "openai" | "google" | "replicate"
  usdCost   Float
  createdAt DateTime @default(now())

  @@index([provider, createdAt])
}

// One row per request that counts against a rate limit. A bucket is checked
// by counting rows newer than (now - windowMs); never held in memory so
// limits survive process restarts.
model RateLimitHit {
  id        String   @id @default(cuid())
  bucket    String // e.g. "extract-brand:ip:<hash>" or "global:score-candidate"
  createdAt DateTime @default(now())

  @@index([bucket, createdAt])
}

// Suspicious or blocked events for later review: prompt-injection attempts,
// SSRF blocks, MCP auth failures, budget exhaustion.
model SecurityEvent {
  id        String   @id @default(cuid())
  type      String
  detail    String
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}
