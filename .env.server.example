# Copy to .env.server and fill in. Never commit the real file.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...
REPLICATE_API_TOKEN=r8_...
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Wasp email/password auth. Resend, Postmark, Mailgun, SES, etc. can all be
# used through SMTP as long as these match the provider's credentials.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=...
SMTP_PASSWORD=...

# --- Security: cost caps ---
ANTHROPIC_DAILY_USD_CAP=0.25
OPENAI_DAILY_USD_CAP=0.25
GOOGLE_DAILY_USD_CAP=0.25
REPLICATE_DAILY_USD_CAP=0.25

# Optional, one-time migration input only:
# set MCP_SHARED_SECRET to the old shared secret, run `npm run migrate:mcp-secret`,
# then remove it. Runtime MCP auth never reads this variable.
# MCP_SHARED_SECRET=
