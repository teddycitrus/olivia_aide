    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "chroma-js": "^3.1.2",
    "helmet": "^6.0.0",
    "node-vibrant": "^3.2.1-alpha.1",
    "openai": "^4.73.0",
    "pino": "^9.6.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router": "^7.12.0",
